# Segredo usado para assinar os tokens de sessão (login e verificação no
# servidor de sockets em server.js). Defina um valor longo e aleatório em
# produção — sem isso, um valor de desenvolvimento inseguro é usado.
SESSION_SECRET=troque-por-uma-string-longa-e-aleatoria

# Opcional: caminho do arquivo de usuários. Se não definido, o app usa
# /data/usuarios.json automaticamente quando existe um volume montado em
# /data (ex.: Railway), ou ./data/usuarios-db.json em desenvolvimento local.
# DATABASE_PATH=/data/usuarios.json

# Necessário para "Esqueci minha senha" e o e-mail de boas-vindas ao criar
# usuário. Crie uma conta em resend.com e gere uma API key.
# RESEND_API_KEY=re_xxxxxxxx

# Opcional: remetente dos e-mails. Sem domínio verificado no Resend, use o
# padrão (onboarding@resend.dev) — funciona, mas só envia para o e-mail
# com o qual você criou a conta no Resend. Verificando internit.com.br lá,
# pode usar algo como "Internit Office <office@internit.com.br>".
# RESEND_FROM_EMAIL=Internit Office <onboarding@resend.dev>
