# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# arquivo de usuários local (dev) — em produção vive num volume do Railway
/data/usuarios-db.json
/data/usuarios-db.json.tmp
/data/app.db
/data/app.db-journal
/data/app.db-wal
/data/app.db-shm

# histórico de mensagens de chat local (dev) — em produção vive num
# volume do Railway, igual o arquivo de usuários acima
/data/mensagens-db.json
/data/mensagens-db.json.tmp

# progresso/estatísticas do Termo do Dia (dev) — mesmo padrão acima
/data/termo-db.json
/data/termo-db.json.tmp

# typescript
*.tsbuildinfo
next-env.d.ts
